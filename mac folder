   INIT
═══════════════════════════════════════════════════════ */
buildPresets();

// Init preset 0 (Blue) as active
S.color = { h: PRESETS[0].hsl[0], s: PRESETS[0].hsl[1], l: PRESETS[0].hsl[2] };

// iOS hint show/hide
const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent);
if (isIOS) {
  document.getElementById('iosHint').style.display = 'block';
}
</script>
